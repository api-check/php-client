{
  "name": "api-check/php-client",
  "description": "A wrapper around ApiCheck API to validate addresses.",
  "keywords": [
    "apicheck",
    "laravel",
    "address-validation",
    "postal-code",
    "address-api",
    "address-verification"
  ],
  "homepage": "https://apicheck.nl/",
  "license": "MIT",
  "type": "library",
  "authors": [
    {
      "name": "ApiCheck",
      "email": "support@apicheck.nl",
      "role": "Developer"
    }
  ],
  "require": {
    "php": "^7.4|^8.0|^8.1|^8.2|^8.3|^8.5",
    "ext-curl": "*",
    "ext-json": "*",
    "guzzlehttp/guzzle": "^7.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.0|^10.0|^11.0"
  },
  "config": {
    "sort-packages": true,
    "optimize-autoloader": true,
    "prefer-stable": true
  },
  "autoload": {
    "psr-4": {
      "ApiCheck\\Api\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "ApiCheck\\Api\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit --dont-report-useless-tests --no-coverage",
    "test:coverage": "phpunit --coverage-html coverage --dont-report-useless-tests",
    "analyze": "phpstan analyse --memory-limit=2G",
    "cs:check": "phpcs --standard=PSR12 --warning-severity=0 src tests",
    "cs:fix": "phpcbf --standard=PSR12 src tests",
    "quality": [
      "@cs:check",
      "@analyze",
      "@test"
    ]
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}